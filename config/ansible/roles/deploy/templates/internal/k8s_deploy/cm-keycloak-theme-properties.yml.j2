---

apiVersion: v1
kind: ConfigMap
metadata:
  name: configmap-{{ stage }}-{{ project_name }}-keycloak-theme-properties
  namespace: hiv
data:
  theme-properties: |
    parent=keycloak
    import=common/keycloak
    styles=css/login.css
    ADMIN_APP_URL=https://{{ admin_webapp_url }}
    THERAPIST_APP_URL=https://{{ therapist_webapp_url }}
    LIBRARY_APP_URL=https://{{ hicadmin_webapp_url }}
